{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "allowJs": true,
    "noEmit": true,
    "paths": {
      "@/*": ["./src/*"],
      "@primefoods/types": ["../../packages/types/src/index.ts"]
    }
  },
  "include": ["src", "app", "babel.config.js"],
  "exclude": ["dist", "node_modules", ".expo"]
}
